{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/og/recept/[slug].ts": {
      "includeFiles": "dist/**"
    }
  },
  "routes": [
    {
      "src": "/recept/([^/]+?)/?",
      "dest": "/api/og/recept/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
