{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/og/recept/[slug].ts": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/recept/:slug",
      "destination": "/api/og/recept/:slug"
    },
    {
      "source": "/:path((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
